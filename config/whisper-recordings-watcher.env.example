# Local watcher configuration. The installer copies this file to
# ~/.config/whisper-recordings-watcher.env only when that file does not exist.

WATCH_DIR="/home/jakub-pelka/MobileTransfer/Recordings"

LANGUAGE="sv"
KB_MODEL="large"
KB_REVISION="standard"

# Used automatically when LANGUAGE is not Swedish.
WHISPER_MODEL="large-v3-turbo"
WHISPER_PRESET="fast"

STABILITY_SECONDS="90"
SCAN_INTERVAL_SECONDS="120"

RECURSIVE_SCAN="false"
RETRY_FAILED="true"
RETRY_DELAY_SECONDS="3600"
